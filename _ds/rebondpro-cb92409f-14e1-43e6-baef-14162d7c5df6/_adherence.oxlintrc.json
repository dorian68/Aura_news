{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app/**",
              "assets/**",
              "export/blog-lebonrebond/assets/**",
              "export/lebonrebond-complet/app/**",
              "export/lebonrebond-complet/assets/**",
              "export/lebonrebond-site/assets/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--bg",
      "--border",
      "--border-2",
      "--border-strong",
      "--danger",
      "--danger-bg",
      "--danger-border",
      "--danger-strong",
      "--font",
      "--ink",
      "--ink-2",
      "--ink-3",
      "--ink-4",
      "--pill",
      "--positive",
      "--positive-600",
      "--positive-bg",
      "--positive-border",
      "--primary",
      "--primary-100",
      "--primary-200",
      "--primary-50",
      "--primary-600",
      "--primary-700",
      "--primary-tint",
      "--r",
      "--r-lg",
      "--r-md",
      "--r-sm",
      "--r-xl",
      "--r-xs",
      "--shadow",
      "--shadow-lg",
      "--shadow-pop",
      "--shadow-sm",
      "--shadow-xs",
      "--sidebar-w",
      "--sky",
      "--sky-bg",
      "--surface",
      "--surface-2",
      "--surface-3",
      "--teal",
      "--topbar-h",
      "--violet-soft",
      "--warn",
      "--warn-bg",
      "--warn-border",
      "--warn-strong"
    ],
    "tokenKinds": {
      "--bg": "color",
      "--surface": "color",
      "--surface-2": "color",
      "--surface-3": "color",
      "--ink": "color",
      "--ink-2": "color",
      "--ink-3": "color",
      "--ink-4": "color",
      "--border": "color",
      "--border-2": "color",
      "--border-strong": "color",
      "--primary": "color",
      "--primary-600": "color",
      "--primary-700": "color",
      "--primary-50": "color",
      "--primary-100": "color",
